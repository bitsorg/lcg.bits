+# Force the pure-python "dumb" dbm backend for ALL Python versions: it writes
+# <name>.dat (+ .dir/.bak) -- the file GaudiToolbox.cmake (patched) declares as
+# the merge output and installs (Gaudi.confdb2.dat).  The guard above only fires
+# for 3.13.0-3.13.7 / 3.14.0 (not the 3.13.11 used here), and the host default
+# backend is gdbm, which writes "Gaudi.confdb2" with no .dat suffix, so install
+# would fail with "cannot find .../Gaudi.confdb2.dat".
+import dbm
+import dbm.dumb
+
+dbm._defaultmod = dbm.dumb
 
