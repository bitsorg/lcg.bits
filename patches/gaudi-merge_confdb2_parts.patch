--- a/GaudiKernel/scripts/merge_confdb2_parts
+++ b/GaudiKernel/scripts/merge_confdb2_parts
@@ -22,9 +22,22 @@
     (3, 13, 0) <= sys.version_info <= (3, 13, 7) or sys.version_info[:3] == (3, 14, 0)
 ) and sys.platform.startswith("linux"):
     import dbm
     import dbm.gnu
 
     dbm._defaultmod = dbm.gnu
 
+# Make the merged confdb2 a single file named exactly "<Project>.confdb2" on
+# EVERY platform by forcing Python's sqlite3 dbm backend (the default since
+# Python 3.13, pure-stdlib so always present).  This overrides the platform-
+# specific default/selection above (gdbm or sqlite3 -> "<Project>.confdb2";
+# ndbm -> ".confdb2.db"; dumbdbm -> ".confdb2.dat"+.dir+.bak), so the cmake
+# install rule and the runtime reader always agree on one name everywhere.
+import dbm
+try:
+    import dbm.sqlite3
+    dbm._defaultmod = dbm.sqlite3
+except ImportError:
+    pass
+
